# Copy to .dev.vars (gitignored) for local `wrangler dev`.
SONIOX_API_KEY=your-soniox-api-key
APP_AUTH_TOKEN=any-shared-secret
# Local dev has no Cloudflare credentials, so the remote Workers AI binding
# (env.AI) is unavailable — DEV_FAKE_AI=1 swaps in deterministic stubs for
# LLM calls (section 20) and embeddings (section 30). Remove for real deploys.
DEV_FAKE_AI=1
# Optional: override the LLM model id used when env.AI IS available.
# AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
