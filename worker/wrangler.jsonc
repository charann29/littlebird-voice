// Canonical Worker config (JSONC — NOT wrangler.toml). All bindings (D1,
// Queues, future Vectorize/R2/etc.) are declared here.
//
// Local dev: `wrangler dev` runs D1 + Queues via local simulators — no
// Cloudflare account needed. Secrets come from `.dev.vars` (gitignored).
//
// Deploy (when hosting is decided): fill `database_id` after
// `wrangler d1 create littlebird-voice`, create the queues, set secrets —
// see worker/README.md.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "littlebird-voice",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "littlebird-voice",
      // Placeholder — replace with the real id from `wrangler d1 create`
      // before a remote deploy. Local dev ignores it.
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "INGEST_QUEUE",
        "queue": "littlebird-ingest"
      }
    ],
    // Consumer config is provisioned here, but the single dispatcher
    // (worker/src/queue/consumer.ts registering the `queue()` handler) is
    // owned by section 30 (its T3). Until then src/index.ts exports a
    // temporary no-op queue handler so `wrangler dev` starts cleanly.
    "consumers": [
      {
        "queue": "littlebird-ingest",
        "max_retries": 3,
        "retry_delay": 30,
        "dead_letter_queue": "littlebird-ingest-dlq"
      }
    ]
  },
  // Workers AI (embeddings @cf/baai/bge-m3). No local simulator — local dev
  // sets DEV_FAKE_AI=1 in .dev.vars and never touches this binding.
  // -------------------------------------------------------------------------
  // Workers AI + Vectorize bindings (section 30 — memory & semantic search).
  //
  // COMMENTED OUT because neither has a local simulator and declaring them
  // makes `wrangler dev` / vitest-pool-workers demand Cloudflare credentials
  // (they proxy to the real service even in dev). This project is local-dev
  // only for now (docs/plans/v2/decisions.md #1); local dev/tests set
  // DEV_FAKE_AI=1 + DEV_LOCAL_VECTOR=1 in .dev.vars and use the deterministic
  // hash embedder (src/memory/provider.ts) + the D1-backed dev vector index
  // (src/memory/index-store.ts) instead.
  //
  // BEFORE A REAL DEPLOY: uncomment both blocks, remove the DEV_* vars, and
  // provision the index:
  //   npx wrangler vectorize create littlebird-memory --dimensions=1024 --metric=cosine
  //   npx wrangler vectorize create-metadata-index littlebird-memory --property-name=kind --type=string
  //   npx wrangler vectorize create-metadata-index littlebird-memory --property-name=session_id --type=string
  //   npx wrangler vectorize create-metadata-index littlebird-memory --property-name=created_at --type=number
  // (metadata indexes MUST exist before the first vector insert).
  //
  // "ai": { "binding": "AI" },
  // "vectorize": [
  //   { "binding": "VECTORIZE", "index_name": "littlebird-memory" }
  // ],
  // -------------------------------------------------------------------------
  // Section 20 (AI features): LLM model id — read by src/ai/provider.ts,
  // never hardcoded at call sites. The same commented-out "ai" binding above
  // is what section 20's WorkersAiProvider uses when deployed; local dev
  // (DEV_FAKE_AI=1) uses the deterministic stub provider instead.
  "vars": {
    "AI_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
    // Section 40 (integrations): OAuth redirect bases — NEVER derived from the
    // incoming Host header. Local dev defaults; point both at the deployed
    // URLs (or custom domain) for a real deploy.
    "APP_BASE_URL": "http://localhost:5173",
    "WORKER_BASE_URL": "http://localhost:8787"
    // Integration secrets (via `wrangler secret put` / .dev.vars — never here):
    //   GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET
    //   SLACK_CLIENT_ID / SLACK_CLIENT_SECRET
    //   NOTION_CLIENT_ID / NOTION_CLIENT_SECRET
    //   INTEGRATIONS_TOKEN_KEY / OAUTH_STATE_SIGNING_KEY (openssl rand -base64 32)
    // All optional: local dev works without them until Connect is invoked.
  },
  // Section 40: calendar auto-create cron (decisions.md #4) — every 15 min,
  // pre-creates sessions for events starting within the lookahead window
  // (CALENDAR_AUTOCREATE_WINDOW_HOURS, default 24), deduped per event.
  // Local dev: `wrangler dev --test-scheduled` + curl "http://localhost:8787/__scheduled".
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "assets": {
    "directory": "../dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
