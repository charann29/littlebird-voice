# The frontend needs no env vars — the Soniox key lives server-side.
#
# Local dev flow (two terminals):
#   1. cd worker && cp .dev.vars.example .dev.vars   # set SONIOX_API_KEY + APP_AUTH_TOKEN
#      npx wrangler d1 migrations apply littlebird-voice --local
#      npm run dev                                   # API on http://localhost:8787
#   2. npm run dev                                   # Vite proxies /api -> :8787
#
# Then paste the APP_AUTH_TOKEN into the app's settings (stored in
# localStorage) to enable transcription + sync.
